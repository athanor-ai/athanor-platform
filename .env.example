# =============================================================================
# Athanor Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your Supabase project values.
# See: https://supabase.com/docs/guides/getting-started/quickstarts/nextjs

# ---------------------------------------------------------------------------
# PUBLIC (safe to expose to the browser via NEXT_PUBLIC_ prefix)
# ---------------------------------------------------------------------------
# These are embedded in the client JS bundle and visible to end users.
# The anon key has limited permissions enforced by RLS policies.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# SERVER-ONLY — NEVER prefix with NEXT_PUBLIC_
# ---------------------------------------------------------------------------
# SECURITY: The service role key bypasses Row Level Security and has full
# database access. It must ONLY be used in server-side code (API routes,
# Server Actions, server components) and must NEVER be exposed to the
# browser, client components, or frontend bundles.
#
# Exposing this key would allow any user to bypass tenant isolation,
# read/write all organizations' data, and access encrypted credentials.
#
# In Vercel, add this as a "Sensitive" environment variable and restrict
# it to the "Production" and "Preview" environments.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
